# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Random secret for signing session cookies (long random string)
AUTH_SECRET=replace-with-a-long-random-string

# Public site URL used in password-reset emails (no trailing slash)
APP_URL=http://localhost:3000

# Resend (https://resend.com) — password reset emails
RESEND_API_KEY=
# Verified sender, e.g. "bucketlist.ai <noreply@yourdomain.com>"
EMAIL_FROM=

# Google AI Studio / Gemini API key
GOOGLE_GENERATIVE_AI_API_KEY=
